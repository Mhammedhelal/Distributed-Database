{
  "server": { "port": 8080 },
  "mysql": { "dsn": "root:rootpass@tcp(mysql-master:3306)/" },
  "cluster": {
    "node_id": "1",
    "self_address": "http://master:8080",
    "worker_addresses": [
      "http://worker1:8081",
      "http://worker2:8082"
    ],
    "heartbeat_interval": "5s",
    "miss_threshold": 3
  },
  "auth": {
    "hmac_secret": "change-me-in-production",
    "token_ttl": "30s"
  },
  "wal": { "path": "/data/master.wal" }
}