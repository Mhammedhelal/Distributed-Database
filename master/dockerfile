# ── Stage 1: build ────────────────────────────────────────────────────────────
FROM golang:1.22-alpine AS builder

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 \
    go build -ldflags="-s -w" -o /master ./cmd/server

# ── Stage 2: runtime ──────────────────────────────────────────────────────────
FROM scratch

COPY --from=builder /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/
COPY --from=builder /master /master
COPY --from=builder /src/config/master.json /config/master.json

RUN mkdir -p /data

EXPOSE 8080

ENV MYSQL_DSN="root:rootpass@tcp(mysql-master:3306)/" \
    HMAC_SECRET="change-me-in-production" \
    NODE_ID="1" \
    SELF_ADDRESS="http://master:8080"

ENTRYPOINT ["/master", "-config", "/config/master.json"]