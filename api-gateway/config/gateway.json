{
  "server": {
    "port": 8000,
    "read_timeout": "15s",
    "write_timeout": "15s",
    "shutdown_timeout": "10s"
  },
  "nodes": {
    "master": { "id": "master-1", "address": "http://localhost:8080" },
    "workers": [
      { "id": "worker-1", "address": "http://localhost:8081" },
      { "id": "worker-2", "address": "http://localhost:8082" }
    ]
  },
  "auth": {
    "hmac_secret": "change-me-in-production",
    "token_ttl": "30s",
    "client_api_key": ""
  },
  "rate_limit": { "requests_per_second": 100, "burst": 200 }
}
